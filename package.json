{
    "name": "controle-ponto",
    "version": "1.0.0",
    "description": "App de controle de ponto pessoal",
    "scripts": {
        "start": "cd backend && npm start",
        "dev": "cd backend && npm run dev",
        "docker:build": "docker compose build",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "docker:logs": "docker compose logs -f",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:api": "vitest run tests/integration"
    },
    "devDependencies": {
        "vitest": "^2.1.9"
    }
}
